# -----------------------------------------------------------------------------
# "The Daily Audit" Pipeline Environment Variables
# Copy this file to '.env' and fill in your credentials.
# -----------------------------------------------------------------------------

# Google GenAI API Credentials (for Gemini 3.1 Pro & Gemini 3 Flash Image)
GEMINI_API_KEY="AIzaSyYourActualAPIKeyHere"

# Azure Cognitive Services Speech Credentials
AZURE_SPEECH_KEY="YourAzureSpeechKeyHere"
AZURE_SPEECH_REGION="southeastasia"
AZURE_VOICE_NAME="en-US-AndrewMultilingualNeural"

# Operational Variables
DEFAULT_FONT_PATH="fonts/Montserrat-Bold.ttf"
IMAGE_RESOLUTION_WIDTH=1080
IMAGE_RESOLUTION_HEIGHT=1920

# Facebook Reels API Configuration
FB_PAGE_ID="YourFacebookPageIDHere"
FB_PAGE_ACCESS_TOKEN="YourFacebookPageAccessTokenHere"
